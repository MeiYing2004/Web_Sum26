# Copy to .env and fill in values (never commit .env)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here
# Optional fallback:
# OPENAI_API_KEY=sk-your-openai-key-here

# Truy cập từ thiết bị khác cùng WiFi (tùy chọn — mặc định frontend tự nhận theo hostname trình duyệt):
# NEXT_PUBLIC_GRAPHQL_URL=http://192.168.1.10:4000/graphql
# NEXT_PUBLIC_WS_URL=ws://192.168.1.10:4000/graphql
#
# Windows Firewall (PowerShell Admin) nếu điện thoại không vào được:
# node scripts/open-lan-firewall.cjs
