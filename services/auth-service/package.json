{
  "name": "@bus/auth-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "prisma generate && tsc && node -e \"require('fs').cpSync('src/generated','dist/generated',{recursive:true})\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@bus/proto": "*",
    "@bus/shared": "*",
    "@grpc/grpc-js": "^1.12.6",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.3",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
