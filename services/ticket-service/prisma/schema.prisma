generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id           String   @id @default(cuid())
  bookingId    String
  bookingCode  String
  passengerName String
  seatId       String
  routeName    String
  pickupPoint  String
  dropoffPoint String
  departureTime String
  busPlate     String
  qrCode       String
  htmlContent  String
  createdAt    DateTime @default(now())
}
